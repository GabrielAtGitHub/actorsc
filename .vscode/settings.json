{
    // ---- CMake Tools ---------------------------------------------------
    "cmake.generator": "Ninja",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,
    "cmake.configureSettings": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "CMAKE_CXX_COMPILER": "clang++-18",
        "CMAKE_C_COMPILER": "clang-18"
    },
    // ninja/cmake installed via pip land in ~/.local/bin, which VS Code may not
    // have on PATH; make sure CMake Tools and the integrated terminal find them.
    "cmake.environment": {
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
    },
    "terminal.integrated.env.linux": {
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
    },

    // ---- IntelliSense: clangd ------------------------------------------
    // clangd provides the Type/Class Hierarchy view (which cpptools does not),
    // plus call hierarchy, go-to-definition, find-references, and rename.
    // On the header-only code it needs NO module workarounds — just the
    // compile database. cpptools' IntelliSense engine is disabled to avoid a
    // conflict; the cpptools extension is kept only for the debugger.
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--background-index",
        "--header-insertion=never"
    ],

    // Retained for anyone who re-enables the cpptools engine; ignored while
    // clangd is active.
    "C_Cpp.default.compilerPath": "/usr/bin/clang++-18",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.intelliSenseMode": "linux-clang-x64",

    // ---- Editor --------------------------------------------------------
    "editor.formatOnSave": true,
    "C_Cpp.clang_format_fallbackStyle": "LLVM"
}
