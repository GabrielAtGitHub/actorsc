{
    // ---- CMake Tools (if you use the extension) -------------------------
    "cmake.generator": "Ninja",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,
    "cmake.configureSettings": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "CMAKE_CXX_COMPILER": "clang++-18",
        "CMAKE_C_COMPILER": "clang-18"
    },
    // ninja was installed via pip into ~/.local/bin, which VS Code may not
    // have on PATH; make sure CMake Tools and the integrated terminal find it.
    "cmake.environment": {
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
    },
    "terminal.integrated.env.linux": {
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
    },

    // ---- IntelliSense: clangd (better C++20 module support than cpptools) --
    // cpptools' IntelliSense engine only partially understands `import` of
    // first-party named modules and emits false "could not find module file"
    // (C/C++ 3275) errors. Disable it and let clangd drive IntelliSense; the
    // cpptools extension is kept only for the debugger (see launch.json).
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--background-index",
        "--header-insertion=never",
        "--clang-tidy"
    ],
    // If you installed the system clangd (`sudo apt install clangd-18`), point
    // at it; otherwise remove this line and the extension downloads its own.
    "clangd.path": "clangd-18",

    // Left for anyone who re-enables the cpptools engine; ignored while clangd
    // is active.
    "C_Cpp.default.compilerPath": "/usr/bin/clang++-18",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.intelliSenseMode": "linux-clang-x64",

    // ---- Editor --------------------------------------------------------
    "editor.formatOnSave": true,
    "files.associations": {
        "*.cppm": "cpp",
        "*.ixx": "cpp"
    },
    "C_Cpp.clang_format_fallbackStyle": "LLVM"
}
