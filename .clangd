# clangd project configuration — https://clangd.llvm.org/config
#
# Per-file compile flags come from build/compile_commands.json (generated with
# CMAKE_EXPORT_COMPILE_COMMANDS=ON). Build the project once so the module BMIs
# exist before relying on cross-module IntelliSense.

CompileFlags:
  Compiler: clang++-18

Diagnostics:
  # These analyses produce false positives on C++20 module units, where a
  # symbol may arrive via `import` rather than a textual include.
  UnusedIncludes: None
  MissingIncludes: None
